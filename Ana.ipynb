#P1:Importar a Base de Dados
#P2:Visualizar e tratar a base de dados

import pandas as pd
Cancelamentos=pd.read_csv("Cancelamentos.csv")
#Retirar Informacoes que nao ajudam e que nao ajudam da tabela
Cancelamentos=Cancelamentos.drop(columns="CustomerID")
display(Cancelamentos)
#Retirar as Informacoes Vazias/dropduplicates=exclui resultados duplicados
Cancelamentos=Cancelamentos.dropna()
display(Cancelamentos.info())
#Vai contar quantos 1 e 0 em Numeros Totais
display(Cancelamentos["cancelou"].value_counts(()))
#Percentual
display(Cancelamentos["cancelou"].value_counts(normalize=True).map("{:.2%}".format))
import plotly.express as px
for coluna in Cancelamentos.columns:
    grafico=px.histogram(Cancelamentos, x=coluna, color="cancelou", text_auto=True)
    display(grafico)
#Identificar os pontos aonde o cancelamento e maior,
# Callcenter>4 todos cancelaram,
# dar desconto no contrato anual e trimestral,
# se os clientes possuem mais de 20 dias de atraso no pagamento todos cancelaram
Cond=Cancelamentos["duracao_contrato"]!="Monthly"
Cancelamentos=Cancelamentos[Cond]
Cond=Cancelamentos["ligacoes_callcenter"]<=4
Cancelamentos=Cancelamentos[Cond]
Cond=Cancelamentos["dias_atraso"]<=20
Cancelamentos=Cancelamentos[Cond]
print(Cancelamentos["cancelou"].value_counts(normalize=True).map("{:.2%}".format))
